cat > .gitignore << 'EOF'
# Terraform state files - NEVER commit these
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform plan files
tfplan
*.tfplan

# Terraform directory
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Sensitive variable files - NEVER commit these
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local settings - contains credentials
.claude/settings.local.json
*.local.json

# Environment files - contains secrets
.env
.env.local
.env.*.local

# SSH keys - NEVER commit
*.pem
*.key
id_rsa
id_rsa.pub

# OS files
.DS_Store
Thumbs.db

# VS Code
.vscode/
*.code-workspace

# Logs
*.log
logs/
EOF